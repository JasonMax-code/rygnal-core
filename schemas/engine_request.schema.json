{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.rygnal.local/engine_request.schema.json",
  "title": "Rygnal Engine Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "action",
    "request_id",
    "trusted_repo_path",
    "command",
    "unsafe_local_requested"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "rygnal.engine.v1"
    },
    "action": {
      "type": "string",
      "enum": ["guarded_run.start"]
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "trusted_repo_path": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute path to the trusted Git repository root. Relative paths are rejected."
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Strict argv list. Shell strings and shell=true are intentionally unsupported."
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400,
      "default": 300
    },
    "run_root": {
      "type": ["string", "null"],
      "default": null,
      "description": "Optional absolute run-root path. If omitted, Python chooses a safe default."
    },
    "audit_log_path": {
      "type": ["string", "null"],
      "default": null,
      "description": "Optional absolute audit log path."
    },
    "preserve_workspace": {
      "type": "boolean",
      "default": false
    },
    "unsafe_local_requested": {
      "type": "boolean",
      "description": "Must be explicit. Secure backends are preferred by default."
    },
    "allow_dirty_override": {
      "type": "boolean",
      "default": false
    },
    "untracked_file_policy": {
      "type": "string",
      "enum": ["block", "preserve_and_warn"],
      "default": "block"
    },
    "environment": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "default": "local"
    },
    "user_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "default": "local_user"
    },
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "default": "local_agent"
    },
    "debug": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "include_raw_patch": {
          "type": "boolean",
          "default": false
        },
        "include_stdout": {
          "type": "boolean",
          "default": false
        },
        "include_stderr": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
